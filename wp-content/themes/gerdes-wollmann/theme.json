{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "settings": {
        "appearanceTools": true,
        "layout": {
            "contentSize": "860px",
            "wideSize": "1280px"
        },
        "color": {
            "palette": [
                {
                    "slug": "base",
                    "color": "#FAF6EF",
                    "name": "Base"
                },
                {
                    "slug": "base-2",
                    "color": "#FFFFFF",
                    "name": "Base 2"
                },
                {
                    "slug": "contrast",
                    "color": "#2D4A3E",
                    "name": "Contrast"
                },
                {
                    "slug": "contrast-2",
                    "color": "#3D6355",
                    "name": "Contrast 2"
                },
                {
                    "slug": "accent-1",
                    "color": "#C8963E",
                    "name": "Accent 1"
                },
                {
                    "slug": "accent-2",
                    "color": "#E8C97A",
                    "name": "Accent 2"
                },
                {
                    "slug": "accent-3",
                    "color": "#C4957A",
                    "name": "Accent 3"
                },
                {
                    "slug": "accent-4",
                    "color": "#EDE3D3",
                    "name": "Accent 4"
                }
            ]
        },
        "typography": {
            "fluid": {
                "minFontSize": "13px",
                "maxViewportWidth": "1800px",
                "minViewportWidth": "320px"
            },
            "fontFamilies": [
                {
                    "fontFamily": "'Cormorant Garamond', Georgia, serif",
                    "slug": "heading",
                    "name": "Heading"
                },
                {
                    "fontFamily": "'Cormorant Garamond', Georgia, serif",
                    "slug": "body",
                    "name": "Body"
                },
                {
                    "fontFamily": "'Playfair Display', Georgia, serif",
                    "slug": "playfair",
                    "name": "Playfair Display"
                },
                {
                    "fontFamily": "'Lora', Georgia, serif",
                    "slug": "lora",
                    "name": "Lora"
                },
                {
                    "fontFamily": "'DM Sans', 'Helvetica Neue', sans-serif",
                    "slug": "dm-sans",
                    "name": "DM Sans"
                },
                {
                    "fontFamily": "'Source Serif 4', Georgia, serif",
                    "slug": "source-serif",
                    "name": "Source Serif 4"
                },
                {
                    "fontFamily": "'Libre Baskerville', Georgia, serif",
                    "slug": "libre-baskerville",
                    "name": "Libre Baskerville"
                }
            ],
            "fontSizes": [
                {
                    "slug": "small",
                    "size": "0.85rem",
                    "fluid": {
                        "min": "0.78rem",
                        "max": "0.85rem"
                    },
                    "name": "Small"
                },
                {
                    "slug": "medium",
                    "size": "1rem",
                    "fluid": {
                        "min": "0.9rem",
                        "max": "1rem"
                    },
                    "name": "Medium"
                },
                {
                    "slug": "large",
                    "size": "1.25rem",
                    "fluid": {
                        "min": "1.05rem",
                        "max": "1.25rem"
                    },
                    "name": "Large"
                },
                {
                    "slug": "x-large",
                    "size": "1.75rem",
                    "fluid": {
                        "min": "1.35rem",
                        "max": "1.75rem"
                    },
                    "name": "Extra Large"
                },
                {
                    "slug": "xx-large",
                    "size": "2.25rem",
                    "fluid": {
                        "min": "1.6rem",
                        "max": "2.25rem"
                    },
                    "name": "2X Large"
                },
                {
                    "slug": "huge",
                    "size": "3.5rem",
                    "fluid": {
                        "min": "2.2rem",
                        "max": "3.5rem"
                    },
                    "name": "Huge"
                }
            ]
        },
        "spacing": {
            "units": ["px", "em", "rem", "vh", "vw", "%"],
            "spacingSizes": [
                { "slug": "10", "size": "clamp(0.375rem, 0.75vw, 0.5rem)", "name": "XS" },
                { "slug": "20", "size": "clamp(0.75rem, 1.5vw, 1rem)", "name": "S" },
                { "slug": "30", "size": "clamp(1rem, 2.25vw, 1.5rem)", "name": "M" },
                { "slug": "40", "size": "clamp(1.5rem, 3.5vw, 2.5rem)", "name": "L" },
                { "slug": "50", "size": "clamp(2.5rem, 5.5vw, 4rem)", "name": "XL" },
                { "slug": "60", "size": "clamp(3.5rem, 8vw, 6rem)", "name": "2XL" }
            ]
        }
    },
    "styles": {
        "color": {
            "background": "var:preset|color|base",
            "text": "var:preset|color|contrast"
        },
        "typography": {
            "fontFamily": "var:preset|font-family|body",
            "fontSize": "var:preset|font-size|medium",
            "lineHeight": "1.6"
        },
        "elements": {
            "heading": {
                "typography": {
                    "fontFamily": "var:preset|font-family|heading",
                    "fontWeight": "400",
                    "lineHeight": "1.15"
                },
                "color": {
                    "text": "var:preset|color|contrast"
                }
            },
            "h1": {
                "typography": {
                    "fontSize": "var:preset|font-size|huge",
                    "fontWeight": "300"
                }
            },
            "h2": {
                "typography": {
                    "fontSize": "var:preset|font-size|xx-large",
                    "fontWeight": "400"
                }
            },
            "h3": {
                "typography": {
                    "fontSize": "var:preset|font-size|x-large",
                    "fontWeight": "500"
                }
            },
            "h4": {
                "typography": {
                    "fontSize": "var:preset|font-size|large",
                    "fontWeight": "500"
                }
            },
            "link": {
                "color": {
                    "text": "var:preset|color|accent-1"
                },
                ":hover": {
                    "color": {
                        "text": "var:preset|color|accent-3"
                    }
                }
            }
        },
        "blocks": {
            "core/navigation": {
                "typography": {
                    "fontFamily": "var:preset|font-family|body",
                    "fontSize": "0.8rem",
                    "fontWeight": "500"
                }
            },
            "core/separator": {
                "color": {
                    "text": "var:preset|color|accent-4"
                }
            }
        }
    }
}