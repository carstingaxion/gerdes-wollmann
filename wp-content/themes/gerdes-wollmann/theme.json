{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"color": "#F9FBFA",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#FFFFFF",
					"name": "Base 2",
					"slug": "base-2"
				},
				{
					"color": "#1B2D2A",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#3D5955",
					"name": "Contrast 2",
					"slug": "contrast-2"
				},
				{
					"color": "#0D9488",
					"name": "Accent 1",
					"slug": "accent-1"
				},
				{
					"color": "#5EEAD4",
					"name": "Accent 2",
					"slug": "accent-2"
				},
				{
					"color": "#F59E0B",
					"name": "Accent 3",
					"slug": "accent-3"
				},
				{
					"color": "#E8F0EE",
					"name": "Accent 4",
					"slug": "accent-4"
				}
			]
		},
		"layout": {
			"contentSize": "860px",
			"wideSize": "1280px"
		},
		"spacing": {
			"spacingSizes": [
				{
					"name": "XS",
					"size": "clamp(0.375rem, 0.75vw, 0.5rem)",
					"slug": "10"
				},
				{
					"name": "S",
					"size": "clamp(0.75rem, 1.5vw, 1rem)",
					"slug": "20"
				},
				{
					"name": "M",
					"size": "clamp(1rem, 2.25vw, 1.5rem)",
					"slug": "30"
				},
				{
					"name": "L",
					"size": "clamp(1.5rem, 3.5vw, 2.5rem)",
					"slug": "40"
				},
				{
					"name": "XL",
					"size": "clamp(2.5rem, 5.5vw, 4rem)",
					"slug": "50"
				},
				{
					"name": "2XL",
					"size": "clamp(3.5rem, 8vw, 6rem)",
					"slug": "60"
				}
			],
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw",
				"%"
			]
		},
		"typography": {
			"fluid": {
				"maxViewportWidth": "1800px",
				"minFontSize": "13px",
				"minViewportWidth": "320px"
			},
			"fontFamilies": [
                {
                    "fontFamily": "'Outfit', 'Helvetica Neue', sans-serif",
                    "slug": "heading",
                    "name": "Heading"
                },
                {
                    "fontFamily": "'Nunito Sans', 'Helvetica Neue', sans-serif",
                    "slug": "body",
                    "name": "Body"
                }
			],
			"fontSizes": [
				{
					"fluid": {
						"max": "0.85rem",
						"min": "0.78rem"
					},
					"name": "Small",
					"size": "0.85rem",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "1rem",
						"min": "0.9rem"
					},
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "1.25rem",
						"min": "1.05rem"
					},
					"name": "Large",
					"size": "1.25rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "1.75rem",
						"min": "1.35rem"
					},
					"name": "Extra Large",
					"size": "1.75rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "2.25rem",
						"min": "1.6rem"
					},
					"name": "2X Large",
					"size": "2.25rem",
					"slug": "xx-large"
				},
				{
					"fluid": {
						"max": "3.5rem",
						"min": "2.2rem"
					},
					"name": "Huge",
					"size": "3.5rem",
					"slug": "huge"
				}
			]
		}
	},
	"styles": {
		"blocks": {
			"core/button": {
				"border": {
					"radius": "8px"
				},
				"color": {
					"background": "var(--wp--preset--color--accent-1)",
					"text": "var(--wp--preset--color--base-2)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "500",
					"letterSpacing": "0.12em",
					"textTransform": "uppercase"
				},
				"variations": {
					"outline": {
						"border": {
							"color": "var(--wp--preset--color--accent-1)",
							"width": "1px"
						},
						"color": {
							"text": "var(--wp--preset--color--accent-1)"
						}
					}
				}
			},
			"core/calendar": {
				"color": {
					"background": "var(--wp--preset--color--base-2)",
					"text": "var(--wp--preset--color--contrast)"
				}
			},
			"core/code": {
				"border": {
					"color": "var(--wp--preset--color--accent-4)",
					"radius": "4px",
					"width": "1px"
				},
				"color": {
					"background": "var(--wp--preset--color--accent-4)",
					"text": "var(--wp--preset--color--contrast)"
				},
				"spacing": {
					"padding": {
						"bottom": "var(--wp--preset--spacing--30)",
						"left": "var(--wp--preset--spacing--30)",
						"right": "var(--wp--preset--spacing--30)",
						"top": "var(--wp--preset--spacing--30)"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/cover": {
				"color": {
					"text": "var(--wp--preset--color--base)"
				}
			},
			"core/file": {
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				},
				"elements": {
					"button": {
						"color": {
							"background": "var(--wp--preset--color--contrast)",
							"text": "var(--wp--preset--color--base)"
						},
						"typography": {
							"fontSize": "var(--wp--preset--font-size--small)",
							"fontWeight": "500",
							"letterSpacing": "0.12em",
							"textTransform": "uppercase"
						}
					},
					"link": {
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--accent-3)"
							}
						},
						"color": {
							"text": "var(--wp--preset--color--accent-1)"
						}
					}
				}
			},
			"core/gallery": {
				"elements": {
					"caption": {
						"color": {
							"text": "var(--wp--preset--color--accent-3)"
						},
						"typography": {
							"fontSize": "var(--wp--preset--font-size--small)",
							"fontStyle": "italic"
						}
					}
				}
			},
			"core/image": {
				"elements": {
					"caption": {
						"color": {
							"text": "var(--wp--preset--color--accent-3)"
						},
						"typography": {
							"fontSize": "var(--wp--preset--font-size--small)",
							"fontStyle": "italic"
						}
					}
				}
			},
			"core/navigation": {
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--body)",
					"fontSize": "0.8rem",
					"fontWeight": "500"
				}
			},
			"core/paragraph": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)",
					"fontStyle": "normal",
					"fontWeight": "400"
				}
			},
			"core/post-date": {
				"color": {
					"text": "var(--wp--preset--color--accent-1)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontWeight": "500",
					"letterSpacing": "0.12em",
					"textTransform": "uppercase"
				}
			},
			"core/post-terms": {
				"color": {
					"text": "var(--wp--preset--color--accent-1)"
				},
				"elements": {
					"link": {
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--accent-3)"
							}
						},
						"color": {
							"text": "var(--wp--preset--color--accent-1)"
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/preformatted": {
				"border": {
					"radius": "4px"
				},
				"color": {
					"background": "var(--wp--preset--color--accent-4)",
					"text": "var(--wp--preset--color--contrast)"
				},
				"spacing": {
					"padding": {
						"bottom": "var(--wp--preset--spacing--30)",
						"left": "var(--wp--preset--spacing--30)",
						"right": "var(--wp--preset--spacing--30)",
						"top": "var(--wp--preset--spacing--30)"
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/pullquote": {
				"border": {
					"color": "var(--wp--preset--color--accent-1)",
					"style": "solid",
					"width": "2px 0"
				},
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				},
				"elements": {
					"cite": {
						"color": {
							"text": "var(--wp--preset--color--accent-3)"
						},
						"typography": {
							"fontSize": "var(--wp--preset--font-size--small)",
							"fontStyle": "normal",
							"letterSpacing": "0.1em",
							"textTransform": "uppercase"
						}
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontStyle": "italic",
					"lineHeight": "1.5"
				}
			},
			"core/quote": {
				"border": {
					"color": "var(--wp--preset--color--accent-1)",
					"style": "solid",
					"width": "3px"
				},
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				},
				"elements": {
					"cite": {
						"color": {
							"text": "var(--wp--preset--color--accent-3)"
						},
						"typography": {
							"fontSize": "var(--wp--preset--font-size--small)",
							"fontStyle": "normal",
							"letterSpacing": "0.08em",
							"textTransform": "uppercase"
						}
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontStyle": "italic",
					"lineHeight": "1.7"
				}
			},
			"core/search": {
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				},
				"elements": {
					"button": {
						"color": {
							"background": "var(--wp--preset--color--contrast)",
							"text": "var(--wp--preset--color--base)"
						}
					}
				}
			},
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--accent-2)"
				}
			},
			"core/table": {
				"border": {
					"color": "var(--wp--preset--color--accent-4)"
				},
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				},
				"elements": {
					"caption": {
						"color": {
							"text": "var(--wp--preset--color--accent-3)"
						},
						"typography": {
							"fontSize": "var(--wp--preset--font-size--small)",
							"fontStyle": "italic"
						}
					}
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)"
				},
				"variations": {
					"stripes": {
						"color": {
							"background": "var(--wp--preset--color--base)"
						}
					}
				}
			},
			"core/tag-cloud": {
				"elements": {
					"link": {
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--accent-1)"
							}
						},
						"color": {
							"text": "var(--wp--preset--color--contrast-2)"
						}
					}
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--huge)",
					"fontWeight": "700",
					"letterSpacing": "-0.03em"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"fontWeight": "600",
					"letterSpacing": "-0.02em"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "600"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "600"
				}
			},
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "600",
					"lineHeight": "1.15"
				}
			},
			"link": {
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--accent-3)"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--accent-1)"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		}
	}
}