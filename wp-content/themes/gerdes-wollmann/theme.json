{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"palette": [
				{
					"color": "#FAF6EF",
					"name": "Cream",
					"slug": "cream"
				},
				{
					"color": "#2d4a3e",
					"name": "Forest",
					"slug": "forest"
				},
				{
					"color": "#3D6355",
					"name": "Forest Light",
					"slug": "forest-light"
				},
				{
					"color": "#C8963E",
					"name": "Amber",
					"slug": "amber"
				},
				{
					"color": "#E8C97A",
					"name": "Amber Light",
					"slug": "amber-light"
				},
				{
					"color": "#C4957A",
					"name": "Dusty Rose",
					"slug": "dusty-rose"
				},
				{
					"color": "#EDE3D3",
					"name": "Aged Paper",
					"slug": "aged-paper"
				}
			]
		},
		"layout": {
			"contentSize": "860px",
			"wideSize": "1280px"
		},
		"spacing": {
			"spacingSizes": [
				{
					"name": "XS",
					"size": "clamp(0.375rem, 0.75vw, 0.5rem)",
					"slug": "10"
				},
				{
					"name": "S",
					"size": "clamp(0.75rem, 1.5vw, 1rem)",
					"slug": "20"
				},
				{
					"name": "M",
					"size": "clamp(1rem, 2.25vw, 1.5rem)",
					"slug": "30"
				},
				{
					"name": "L",
					"size": "clamp(1.5rem, 3.5vw, 2.5rem)",
					"slug": "40"
				},
				{
					"name": "XL",
					"size": "clamp(2.5rem, 5.5vw, 4rem)",
					"slug": "50"
				},
				{
					"name": "2XL",
					"size": "clamp(3.5rem, 8vw, 6rem)",
					"slug": "60"
				}
			],
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw",
				"%"
			]
		},
		"typography": {
			"fluid": {
				"maxViewportWidth": "1800px",
				"minFontSize": "13px",
				"minViewportWidth": "320px"
			},
			"fontFamilies": [
				{
					"fontFamily": "'Cormorant Garamond', Georgia, serif",
					"name": "Cormorant Garamond",
					"slug": "cormorant"
				},
				{
					"fontFamily": "'Playfair Display', Georgia, serif",
					"name": "Playfair Display",
					"slug": "playfair"
				},
				{
					"fontFamily": "'Lora', Georgia, serif",
					"name": "Lora",
					"slug": "lora"
				},
				{
					"fontFamily": "'DM Sans', 'Helvetica Neue', sans-serif",
					"name": "DM Sans",
					"slug": "dm-sans"
				},
				{
					"fontFamily": "'Source Serif 4', Georgia, serif",
					"name": "Source Serif 4",
					"slug": "source-serif"
				},
				{
					"fontFamily": "'Libre Baskerville', Georgia, serif",
					"name": "Libre Baskerville",
					"slug": "libre-baskerville"
				}
			],
			"fontSizes": [
				{
					"fluid": {
						"max": "0.85rem",
						"min": "0.78rem"
					},
					"name": "Small",
					"size": "0.85rem",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "1rem",
						"min": "0.9rem"
					},
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "1.25rem",
						"min": "1.05rem"
					},
					"name": "Large",
					"size": "1.25rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "1.75rem",
						"min": "1.35rem"
					},
					"name": "Extra Large",
					"size": "1.75rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "2.25rem",
						"min": "1.6rem"
					},
					"name": "2X Large",
					"size": "2.25rem",
					"slug": "xx-large"
				},
				{
					"fluid": {
						"max": "3.5rem",
						"min": "2.2rem"
					},
					"name": "Huge",
					"size": "3.5rem",
					"slug": "huge"
				}
			]
		}
	},
	"styles": {
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--cormorant)",
					"fontSize": "0.8rem",
					"fontWeight": "500"
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--cream)",
			"text": "var(--wp--preset--color--forest)"
		},
		"elements": {
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--huge)",
					"fontWeight": "300"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"fontWeight": "400"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)",
					"fontWeight": "500"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)",
					"fontWeight": "500"
				}
			},
			"heading": {
				"color": {
					"text": "var(--wp--preset--color--forest)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--cormorant)",
					"fontWeight": "400",
					"lineHeight": "1.15"
				}
			},
			"link": {
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--dusty-rose)"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--amber)"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--cormorant)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.6"
		}
	}
}