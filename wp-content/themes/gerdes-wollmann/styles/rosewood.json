{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Rosewood",
    "settings": {
        "color": {
            "palette": [
                {
                    "slug": "base",
                    "color": "#FBF5F0",
                    "name": "Base"
                },
                {
                    "slug": "base-2",
                    "color": "#FFFAF6",
                    "name": "Base 2"
                },
                {
                    "slug": "contrast",
                    "color": "#3B2030",
                    "name": "Contrast"
                },
                {
                    "slug": "contrast-2",
                    "color": "#6B4453",
                    "name": "Contrast 2"
                },
                {
                    "slug": "accent-1",
                    "color": "#A0522D",
                    "name": "Accent 1"
                },
                {
                    "slug": "accent-2",
                    "color": "#C8956A",
                    "name": "Accent 2"
                },
                {
                    "slug": "accent-3",
                    "color": "#B07D6A",
                    "name": "Accent 3"
                },
                {
                    "slug": "accent-4",
                    "color": "#F0E4DA",
                    "name": "Accent 4"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "'Libre Baskerville', Georgia, serif",
                    "slug": "heading",
                    "name": "Heading"
                },
                {
                    "fontFamily": "'Libre Baskerville', Georgia, serif",
                    "slug": "body",
                    "name": "Body"
                }
            ]
        }
    },
    "styles": {
        "typography": {
            "lineHeight": "1.65",
            "fontSize": "0.95rem"
        },
        "elements": {
            "heading": {
                "typography": {
                    "fontWeight": "700",
                    "lineHeight": "1.2"
                }
            },
            "h1": {
                "typography": {
                    "fontWeight": "400",
                    "letterSpacing": "-0.01em"
                }
            },
            "h2": {
                "typography": {
                    "fontWeight": "400"
                }
            },
            "h3": {
                "typography": {
                    "fontWeight": "700"
                }
            },
            "h4": {
                "typography": {
                    "fontWeight": "700"
                }
            },
            "link": {
                ":hover": {
                    "color": {
                        "text": "var:preset|color|accent-3"
                    }
                }
            }
        },
        "blocks": {
            "core/separator": {
                "color": {
                    "text": "var:preset|color|contrast-2"
                }
            }
        }
    }
}