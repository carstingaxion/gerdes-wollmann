{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Linen & Ink",
    "settings": {
        "color": {
            "palette": [
                {
                    "slug": "base",
                    "color": "#F2EDE4",
                    "name": "Base"
                },
                {
                    "slug": "base-2",
                    "color": "#FAF7F2",
                    "name": "Base 2"
                },
                {
                    "slug": "contrast",
                    "color": "#1A1A18",
                    "name": "Contrast"
                },
                {
                    "slug": "contrast-2",
                    "color": "#3A3A36",
                    "name": "Contrast 2"
                },
                {
                    "slug": "accent-1",
                    "color": "#B8860B",
                    "name": "Accent 1"
                },
                {
                    "slug": "accent-2",
                    "color": "#D4A84B",
                    "name": "Accent 2"
                },
                {
                    "slug": "accent-3",
                    "color": "#8B7355",
                    "name": "Accent 3"
                },
                {
                    "slug": "accent-4",
                    "color": "#E8DFD0",
                    "name": "Accent 4"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "'Playfair Display', Georgia, serif",
                    "slug": "heading",
                    "name": "Heading"
                },
                {
                    "fontFamily": "'Lora', Georgia, serif",
                    "slug": "body",
                    "name": "Body"
                }
            ]
        }
    },
    "styles": {
        "color": {
            "background": "var:preset|color|contrast",
            "text": "var:preset|color|base"
        },
        "typography": {
            "lineHeight": "1.65"
        },
        "elements": {
            "heading": {
                "color": {
                    "text": "var:preset|color|base"
                }
            },
            "h1": {
                "typography": {
                    "letterSpacing": "-0.02em"
                }
            },
            "link": {
                "color": {
                    "text": "var:preset|color|accent-2"
                },
                ":hover": {
                    "color": {
                        "text": "var:preset|color|accent-1"
                    }
                }
            }
        },
        "blocks": {
            "core/separator": {
                "color": {
                    "text": "var:preset|color|contrast-2"
                }
            },
            "core/button": {
                "color": {
                    "background": "var:preset|color|accent-1",
                    "text": "var:preset|color|contrast"
                },
                "variations": {
                    "outline": {
                        "color": {
                            "text": "var:preset|color|base"
                        },
                        "border": {
                            "color": "var:preset|color|base"
                        }
                    }
                }
            },
            "core/cover": {
                "color": {
                    "text": "var:preset|color|base"
                }
            },
            "core/quote": {
                "color": {
                    "text": "var:preset|color|base"
                },
                "border": {
                    "color": "var:preset|color|accent-2"
                },
                "elements": {
                    "cite": {
                        "color": {
                            "text": "var:preset|color|accent-3"
                        }
                    }
                }
            },
            "core/pullquote": {
                "color": {
                    "text": "var:preset|color|base"
                },
                "border": {
                    "color": "var:preset|color|accent-2"
                },
                "elements": {
                    "cite": {
                        "color": {
                            "text": "var:preset|color|accent-3"
                        }
                    }
                }
            },
            "core/table": {
                "color": {
                    "text": "var:preset|color|base"
                },
                "border": {
                    "color": "var:preset|color|contrast-2"
                },
                "elements": {
                    "caption": {
                        "color": {
                            "text": "var:preset|color|accent-3"
                        }
                    }
                },
                "variations": {
                    "stripes": {
                        "color": {
                            "background": "var:preset|color|contrast"
                        }
                    }
                }
            },
            "core/image": {
                "elements": {
                    "caption": {
                        "color": {
                            "text": "var:preset|color|accent-3"
                        }
                    }
                }
            },
            "core/gallery": {
                "elements": {
                    "caption": {
                        "color": {
                            "text": "var:preset|color|accent-3"
                        }
                    }
                }
            },
            "core/code": {
                "color": {
                    "background": "var:preset|color|contrast-2",
                    "text": "var:preset|color|base"
                },
                "border": {
                    "color": "var:preset|color|contrast-2"
                }
            },
            "core/preformatted": {
                "color": {
                    "background": "var:preset|color|contrast-2",
                    "text": "var:preset|color|base"
                }
            },
            "core/post-date": {
                "color": {
                    "text": "var:preset|color|accent-2"
                }
            },
            "core/post-terms": {
                "color": {
                    "text": "var:preset|color|accent-2"
                },
                "elements": {
                    "link": {
                        "color": {
                            "text": "var:preset|color|accent-2"
                        },
                        ":hover": {
                            "color": {
                                "text": "var:preset|color|accent-1"
                            }
                        }
                    }
                }
            },
            "core/file": {
                "elements": {
                    "button": {
                        "color": {
                            "background": "var:preset|color|accent-1",
                            "text": "var:preset|color|contrast"
                        }
                    }
                }
            },
            "core/search": {
                "color": {
                    "text": "var:preset|color|base"
                },
                "elements": {
                    "button": {
                        "color": {
                            "background": "var:preset|color|accent-1",
                            "text": "var:preset|color|contrast"
                        }
                    }
                }
            },
            "core/calendar": {
                "color": {
                    "text": "var:preset|color|base",
                    "background": "var:preset|color|contrast-2"
                }
            },
            "core/tag-cloud": {
                "elements": {
                    "link": {
                        "color": {
                            "text": "var:preset|color|accent-4"
                        },
                        ":hover": {
                            "color": {
                                "text": "var:preset|color|accent-2"
                            }
                        }
                    }
                }
            }
        }
    }
}