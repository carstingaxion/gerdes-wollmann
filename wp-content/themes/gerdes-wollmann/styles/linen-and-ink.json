{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Linen & Ink",
    "settings": {
        "color": {
            "palette": [
                {
                    "slug": "base",
                    "color": "#F2EDE4",
                    "name": "Base"
                },
                {
                    "slug": "base-2",
                    "color": "#FAF7F2",
                    "name": "Base 2"
                },
                {
                    "slug": "contrast",
                    "color": "#1A1A18",
                    "name": "Contrast"
                },
                {
                    "slug": "contrast-2",
                    "color": "#3A3A36",
                    "name": "Contrast 2"
                },
                {
                    "slug": "accent-1",
                    "color": "#B8860B",
                    "name": "Accent 1"
                },
                {
                    "slug": "accent-2",
                    "color": "#D4A84B",
                    "name": "Accent 2"
                },
                {
                    "slug": "accent-3",
                    "color": "#8B7355",
                    "name": "Accent 3"
                },
                {
                    "slug": "accent-4",
                    "color": "#E8DFD0",
                    "name": "Accent 4"
                }
            ]
        }
    },
    "styles": {
        "color": {
            "background": "var:preset|color|contrast",
            "text": "var:preset|color|base"
        },
        "typography": {
            "fontFamily": "var:preset|font-family|lora",
            "lineHeight": "1.65"
        },
        "elements": {
            "heading": {
                "color": {
                    "text": "var:preset|color|base"
                },
                "typography": {
                    "fontFamily": "var:preset|font-family|playfair"
                }
            },
            "h1": {
                "typography": {
                    "letterSpacing": "-0.02em"
                }
            },
            "link": {
                "color": {
                    "text": "var:preset|color|accent-2"
                },
                ":hover": {
                    "color": {
                        "text": "var:preset|color|accent-1"
                    }
                }
            }
        },
        "blocks": {
            "core/navigation": {
                "typography": {
                    "fontFamily": "var:preset|font-family|lora"
                }
            },
            "core/separator": {
                "color": {
                    "text": "var:preset|color|contrast-2"
                }
            }
        }
    }
}