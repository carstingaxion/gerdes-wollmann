{
    "$schema": "https://schemas.wp.org/trunk/theme.json",
    "version": 3,
    "title": "Morning Mist",
    "settings": {
        "color": {
            "palette": [
                {
                    "slug": "base",
                    "color": "#F4F6F8",
                    "name": "Base"
                },
                {
                    "slug": "base-2",
                    "color": "#FFFFFF",
                    "name": "Base 2"
                },
                {
                    "slug": "contrast",
                    "color": "#2C3E50",
                    "name": "Contrast"
                },
                {
                    "slug": "contrast-2",
                    "color": "#5D7B93",
                    "name": "Contrast 2"
                },
                {
                    "slug": "accent-1",
                    "color": "#6B8F71",
                    "name": "Accent 1"
                },
                {
                    "slug": "accent-2",
                    "color": "#A3C4A8",
                    "name": "Accent 2"
                },
                {
                    "slug": "accent-3",
                    "color": "#8FA3B0",
                    "name": "Accent 3"
                },
                {
                    "slug": "accent-4",
                    "color": "#E8ECF0",
                    "name": "Accent 4"
                }
            ]
        },
        "typography": {
            "fontFamilies": [
                {
                    "fontFamily": "'Source Serif 4', Georgia, serif",
                    "slug": "heading",
                    "name": "Heading"
                },
                {
                    "fontFamily": "'DM Sans', 'Helvetica Neue', sans-serif",
                    "slug": "body",
                    "name": "Body"
                }
            ]
        }
    },
    "styles": {
        "elements": {
            "heading": {
                "typography": {
                    "lineHeight": "1.2"
                }
            },
            "h1": {
                "typography": {
                    "fontWeight": "300"
                }
            },
            "h2": {
                "typography": {
                    "fontWeight": "300"
                }
            },
            "link": {
                ":hover": {
                    "color": {
                        "text": "var:preset|color|contrast-2"
                    }
                }
            }
        },
        "blocks": {
            "core/separator": {
                "color": {
                    "text": "var:preset|color|accent-3"
                }
            },
            "core/button": {
                "color": {
                    "background": "var:preset|color|accent-1",
                    "text": "var:preset|color|base-2"
                },
                "variations": {
                    "outline": {
                        "color": {
                            "text": "var:preset|color|accent-1"
                        },
                        "border": {
                            "color": "var:preset|color|accent-1"
                        }
                    }
                }
            },
            "core/cover": {
                "color": {
                    "text": "var:preset|color|base-2"
                }
            },
            "core/quote": {
                "border": {
                    "color": "var:preset|color|accent-1"
                },
                "elements": {
                    "cite": {
                        "color": {
                            "text": "var:preset|color|contrast-2"
                        }
                    }
                }
            },
            "core/pullquote": {
                "border": {
                    "color": "var:preset|color|accent-1"
                },
                "elements": {
                    "cite": {
                        "color": {
                            "text": "var:preset|color|contrast-2"
                        }
                    }
                }
            },
            "core/table": {
                "border": {
                    "color": "var:preset|color|accent-4"
                },
                "elements": {
                    "caption": {
                        "color": {
                            "text": "var:preset|color|contrast-2"
                        }
                    }
                },
                "variations": {
                    "stripes": {
                        "color": {
                            "background": "var:preset|color|base"
                        }
                    }
                }
            },
            "core/image": {
                "elements": {
                    "caption": {
                        "color": {
                            "text": "var:preset|color|contrast-2"
                        }
                    }
                }
            },
            "core/gallery": {
                "elements": {
                    "caption": {
                        "color": {
                            "text": "var:preset|color|contrast-2"
                        }
                    }
                }
            },
            "core/code": {
                "color": {
                    "background": "var:preset|color|accent-4",
                    "text": "var:preset|color|contrast"
                },
                "border": {
                    "color": "var:preset|color|accent-4"
                }
            },
            "core/preformatted": {
                "color": {
                    "background": "var:preset|color|accent-4",
                    "text": "var:preset|color|contrast"
                }
            },
            "core/file": {
                "elements": {
                    "button": {
                        "color": {
                            "background": "var:preset|color|accent-1",
                            "text": "var:preset|color|base-2"
                        }
                    }
                }
            },
            "core/search": {
                "elements": {
                    "button": {
                        "color": {
                            "background": "var:preset|color|accent-1",
                            "text": "var:preset|color|base-2"
                        }
                    }
                }
            },
            "core/calendar": {
                "color": {
                    "background": "var:preset|color|base-2"
                }
            },
            "core/tag-cloud": {
                "elements": {
                    "link": {
                        "color": {
                            "text": "var:preset|color|contrast-2"
                        },
                        ":hover": {
                            "color": {
                                "text": "var:preset|color|accent-1"
                            }
                        }
                    }
                }
            }
        }
    }
}